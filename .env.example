# Discord Bot Configuration
# Copy this file to .env and fill in your values

# Discord Bot Token (get it from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_token_here

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=this_is_psg
DB_USER=bot_user
DB_PASSWORD=your_secure_password_here

# Debug Mode (optional)
# When true, only DEBUG_USER can use commands
DEBUG_MODE=false
DEBUG_USER=detrax75

# Discord Role IDs
ROLE_NEWBIE_ID=1453322362484297870
ROLE_MEMBRE_ID=1453322702571049072
ROLE_SAGE_ID=1322971425434501161

# Discord Channel IDs
CHANNEL_ACCUEIL_ID=1453323021497405451
CHANNEL_GENERAL_ID=0
CHANNEL_SAGE_ID=0

# Web / GitHub Pages
# URL du site (page index)
SITE_URL=https://lestat2lioncourt.github.io/discord-bot/
# URL de la carte des membres
WEB_URL=https://lestat2lioncourt.github.io/discord-bot/carte.html
